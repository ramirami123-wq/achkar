{% doc %}
  @prompt
    a style to be luxurious and simple
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-simple-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-luxury-simple__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-luxury-simple__eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    color: {{ block.settings.eyebrow_color }};
    letter-spacing: {{ block.settings.eyebrow_spacing }}px;
    text-transform: uppercase;
    margin: 0 0 {{ block.settings.eyebrow_margin }}px;
    font-weight: 400;
  }

  .ai-luxury-simple__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin }}px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: 1.2;
    letter-spacing: {{ block.settings.heading_spacing }}px;
  }

  .ai-luxury-simple__divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
    margin: {{ block.settings.divider_margin }}px auto;
    {% if block.settings.text_alignment == 'left' %}
      margin-left: 0;
    {% elsif block.settings.text_alignment == 'right' %}
      margin-right: 0;
    {% endif %}
  }

  .ai-luxury-simple__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.text_margin }}px;
    font-weight: 300;
    letter-spacing: 0.3px;
  }

  .ai-luxury-simple__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    font-size: {{ block.settings.button_text_size }}px;
    letter-spacing: {{ block.settings.button_letter_spacing }}px;
    text-transform: uppercase;
    transition: all 0.3s ease;
    margin-top: {{ block.settings.button_margin_top }}px;
  }

  .ai-luxury-simple__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-simple-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-luxury-simple__eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_size | times: 0.9 }}px;
    }

    .ai-luxury-simple__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-luxury-simple__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-luxury-simple__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<luxury-simple-{{ ai_gen_id }}
  class="ai-luxury-simple-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-luxury-simple__container-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <div class="ai-luxury-simple__eyebrow-{{ ai_gen_id }}">
        {{ block.settings.eyebrow }}
      </div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h2 class="ai-luxury-simple__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.show_divider %}
      <div class="ai-luxury-simple__divider-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.text != blank %}
      <div class="ai-luxury-simple__text-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </div>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-luxury-simple__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</luxury-simple-{{ ai_gen_id }}>

<script>
  (function() {
    class LuxurySimple{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('luxury-simple-{{ ai_gen_id }}', LuxurySimple{{ ai_gen_id }});
  })();
</script>

